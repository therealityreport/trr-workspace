# Personal Codex defaults live here.
# Keep TRR-specific settings in the trusted project-local `.codex/config.toml`.

[projects."__TRR_ROOT__"]
trust_level = "trusted"

[mcp_servers.chrome-devtools]
command = "__HOME__/.codex/bin/codex-chrome-devtools-mcp-global.sh"
env = { CODEX_CHROME_MODE = "isolated", CODEX_CHROME_HEADLESS = "1", CODEX_CHROME_SEED_PROFILE_DIR = "__HOME__/.chrome-profiles/codex-agent" }
enabled = true
startup_timeout_sec = 45
tool_timeout_sec = 120

[mcp_servers.figma]
url = "https://mcp.figma.com/mcp"
enabled = true

[mcp_servers.figma-desktop]
url = "http://127.0.0.1:3845/mcp"
enabled = false

[mcp_servers.figma-console]
command = "__HOME__/.codex/bin/codex-figma-console-mcp.sh"
enabled = false

[mcp_servers.playwright]
command = "npx"
args = ["-y", "@playwright/mcp", "--isolated"]
enabled = false

[mcp_servers.github]
url = "https://api.githubcopilot.com/mcp"
bearer_token_env_var = "GITHUB_PAT"

[mcp_servers.context7]
command = "npx"
args = ["-y", "@upstash/context7-mcp"]
enabled = true

[[skills.config]]
path = "__HOME__/.codex/skills/senior-architect"
enabled = false

[[skills.config]]
path = "__HOME__/.codex/skills/senior-devops"
enabled = false

[[skills.config]]
path = "__HOME__/.codex/skills/senior-fullstack"
enabled = false

[[skills.config]]
path = "__HOME__/.codex/skills/senior-backend"
enabled = false

[[skills.config]]
path = "__HOME__/.codex/skills/senior-frontend"
enabled = false

[[skills.config]]
path = "__HOME__/.codex/skills/senior-qa"
enabled = false

[[skills.config]]
path = "__HOME__/.codex/skills/code-reviewer"
enabled = false

[[skills.config]]
path = "__HOME__/.codex/skills/skillcreator"
enabled = false

[[skills.config]]
path = "__HOME__/.codex/skills/social-ingestion-reliability"
enabled = false

[[skills.config]]
path = "__HOME__/.codex/skills/figma-frontend-design-engineer"
enabled = false
