{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://therealityreport.com/schemas/design-docs-agent/source-bundle.schema.json",
  "title": "Design Docs Source Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["canonicalSourceUrl", "html"],
  "properties": {
    "canonicalSourceUrl": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical article URL represented by the saved bundle."
    },
    "html": {
      "description": "Local saved-artifact path(s). Package convention: string values point at saved HTML files on disk, not inline HTML content.",
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": false,
          "properties": {
            "modeA": { "type": "string", "minLength": 1 },
            "modeB": { "type": "string", "minLength": 1 },
            "rendered": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "css": {
      "type": "array",
      "description": "Local saved-artifact paths for companion CSS files.",
      "items": { "type": "string", "minLength": 1 }
    },
    "js": {
      "type": "array",
      "description": "Local saved-artifact paths for companion JavaScript files.",
      "items": { "type": "string", "minLength": 1 }
    },
    "manifests": {
      "type": "array",
      "description": "Local saved-artifact paths for asset manifests recovered from the same session.",
      "items": { "type": "string", "minLength": 1 }
    },
    "har": {
      "type": "string",
      "minLength": 1,
      "description": "Local saved-artifact path for an optional HAR file."
    },
    "screenshots": {
      "type": "object",
      "description": "Local saved-artifact paths for optional screenshots captured during acquisition.",
      "additionalProperties": false,
      "properties": {
        "desktop": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "mobile": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "sourceTree": {
      "type": "object",
      "description": "Local saved-artifact paths for optional source-tree evidence.",
      "additionalProperties": false,
      "properties": {
        "exportedPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "sourceMaps": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "screenshots": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "authoritativeViewport": {
      "type": "string",
      "description": "Viewport that the saved bundle most accurately represents.",
      "enum": ["desktop", "mobile", "both"]
    }
  }
}
