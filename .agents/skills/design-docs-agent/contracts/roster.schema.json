{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://therealityreport.com/schemas/design-docs-agent/roster.schema.json",
  "title": "Design Docs Agent Roster",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "package_version",
    "interface",
    "shared_capabilities",
    "pipeline",
    "skillset"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "package_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "interface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display_name", "short_description", "default_prompt"],
      "properties": {
        "display_name": { "type": "string", "minLength": 1 },
        "short_description": { "type": "string", "minLength": 1 },
        "default_prompt": { "type": "string", "minLength": 1 }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "value", "description"],
            "properties": {
              "type": { "type": "string", "minLength": 1 },
              "value": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "shared_capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "browser.navigate",
          "browser.snapshot",
          "browser.evaluate",
          "browser.network.list",
          "browser.network.get",
          "browser.screenshot",
          "delegate.parallel",
          "fs.edit",
          "check.typecheck"
        ]
      },
      "uniqueItems": true
    },
    "pipeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["phase"],
        "properties": {
          "phase": {
            "type": "string",
            "enum": [
              "validation",
              "pre-extraction",
              "extraction",
              "generation",
              "wiring",
              "verification",
              "closeout"
            ]
          },
          "members": {
            "type": "array",
          "items": {
            "type": "object",
            "oneOf": [
              {
                "required": ["skill"],
                "properties": {
                  "skill": { "type": "string", "minLength": 1 }
                },
                "additionalProperties": false
              },
              {
                "required": ["capability"],
                "properties": {
                  "capability": { "type": "string", "minLength": 1 }
                },
                "additionalProperties": false
              }
            ]
          }
        }
        }
      }
    },
    "skillset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "supporting", "owned"],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "supporting": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/supportingSkill"
          }
        },
        "owned": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ownedSkill"
          }
        }
      }
    }
  },
  "$defs": {
    "phaseList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "validation",
          "pre-extraction",
          "extraction",
          "generation",
          "wiring",
          "post-generation",
          "verification",
          "closeout"
        ]
      },
      "uniqueItems": true
    },
    "supportingSkill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skill", "source", "role", "phases", "wave", "status", "version"],
      "properties": {
        "skill": { "type": "string", "minLength": 1 },
        "source": {
          "type": "string",
          "pattern": "^(?!/).+"
        },
        "role": { "type": "string", "minLength": 1 },
        "phases": { "$ref": "#/$defs/phaseList" },
        "wave": { "type": "integer", "minimum": 1 },
        "status": {
          "type": "string",
          "enum": ["active", "deprecated", "retired"]
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    },
    "ownedSkill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skill", "phases", "wave", "status", "version", "order"],
      "properties": {
        "skill": { "type": "string", "minLength": 1 },
        "phases": { "$ref": "#/$defs/phaseList" },
        "wave": { "type": "integer", "minimum": 1 },
        "status": {
          "type": "string",
          "enum": ["active", "deprecated", "retired"]
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
